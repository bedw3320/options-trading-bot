# === Interactive Brokers ===
TWS_USERID=your_ib_username
TWS_PASSWORD=your_ib_password
# "paper" or "live" - defaults to paper
TRADING_MODE=paper
# IB Gateway connection (defaults work with docker-compose)
IB_GATEWAY_HOST=ib-gateway
IB_GATEWAY_PORT=4002
IB_CLIENT_ID=1

# === AI Model ===
ANTHROPIC_API_KEY=your_anthropic_key_here
# PydanticAI model spec (provider:model)
MODEL_SPEC=anthropic:claude-sonnet-4-5-20250929

# === Tavily (web search) ===
TAVILY_API_KEY=your_tavily_key_here

# === Reddit (social sentiment) ===
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=options-trading-bot/0.3.0

# === Optional ===
# LOG_LEVEL=INFO
# ALLOW_TRADING=false
